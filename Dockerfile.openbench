FROM python:3.12-slim

WORKDIR /app

# Install dependencies
COPY OpenBench/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt gunicorn

# Copy OpenBench source
COPY OpenBench/ .

# Entrypoint handles migrations + admin creation
COPY openbench-entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

EXPOSE 8000

ENTRYPOINT ["/entrypoint.sh"]
