# OpenBench worker credentials (create a dedicated non-admin account)
OPENBENCH_USERNAME=worker
OPENBENCH_PASSWORD=CHANGE_ME

# OpenBench server URL
OPENBENCH_SERVER=https://bench.likeawizard.dev

# Number of threads for the worker (use "auto" for all available CPUs)
WORKER_THREADS=auto

# --- Worker Manager (optional, for automated scaling) ---
# Hetzner API token (required for worker-manager)
HCLOUD_TOKEN=
# Server type for worker instances
HCLOUD_SERVER_TYPE=cpx32
# Number of worker servers to create
HCLOUD_WORKER_COUNT=1
# Hetzner datacenter location
HCLOUD_LOCATION=fsn1
# SSH key name (optional, for debugging access to workers)
HCLOUD_SSH_KEY=
# How often to check for work
POLL_INTERVAL=60s
# Wait time before destroying idle workers
COOLDOWN=5m
# OpenBench worker credentials for cloud workers (injected into cloud-config)
OPENBENCH_WORKER_USER=worker
OPENBENCH_WORKER_PASS=CHANGE_ME
